            "parameters": {
                "jsCode": "const raw = $input.first().json.text || '';\nlet parsed;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    sentiment: 'neutral',\n    hasBadWords: false,\n    isHighlyUrgent: false,\n    isThreatening: false,\n    escalationReason: 'none',\n    category: '',\n    urgency: '',\n    context: '',\n    message: ''\n  };\n}\n\nreturn [{ json: parsed }];"
            },
